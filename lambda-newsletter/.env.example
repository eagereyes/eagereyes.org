# DynamoDB table name
DYNAMODB_TABLE=eagereyes-subscribers

# SES verified sender address
SES_FROM=newsletter@eagereyes.org

# Public site URL (no trailing slash)
SITE_URL=https://eagereyes.org

# API Gateway base URL for this Lambda (no trailing slash) — used in email links
LAMBDA_BASE_URL=https://<api-gateway-id>.execute-api.<region>.amazonaws.com

# Secret key required in X-Send-Key header to authorize newsletter sends
SEND_KEY=<generate a long random string>

# Allowed CORS origin for the subscribe form
ALLOWED_ORIGIN=https://eagereyes.org
