# GitHub Personal Access Token with `repo` scope (write access to eagereyes repo)
GITHUB_TOKEN=ghp_...

# GitHub repo owner and name
GITHUB_OWNER=rkosara
GITHUB_REPO=eagereyes

# Allowed CORS origin (your site's URL)
ALLOWED_ORIGIN=https://eagereyes.org

# SES verified sender address for comment notification emails (leave blank to disable)
SES_FROM=

# Email address to receive comment notifications
NOTIFY_EMAIL=
