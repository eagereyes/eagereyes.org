# URL of the deployed AWS Lambda / API Gateway endpoint
# Set this in .env (which is gitignored) for local dev
VITE_COMMENT_LAMBDA_URL=https://<api-gateway-id>.execute-api.<region>.amazonaws.com/comment

# URL of the newsletter Lambda / API Gateway endpoint (subscribe form)
VITE_SUBSCRIBE_LAMBDA_URL=https://<api-gateway-id>.execute-api.<region>.amazonaws.com
